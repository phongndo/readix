{
	"name": "readix",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:generate": "drizzle-kit generate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@playwright/test": "^1.56.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.10",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.0",
		"globals": "^16.5.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.47.0",
		"vite": "^7.2.2",
		"vitest": "^4.0.10",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@embedpdf/core": "^1.5.0",
		"@embedpdf/engines": "^1.5.0",
		"@embedpdf/pdfium": "^1.5.0",
		"@embedpdf/plugin-interaction-manager": "^1.5.0",
		"@embedpdf/plugin-loader": "^1.5.0",
		"@embedpdf/plugin-pan": "^1.5.0",
		"@embedpdf/plugin-render": "^1.5.0",
		"@embedpdf/plugin-scroll": "^1.5.0",
		"@embedpdf/plugin-selection": "^1.5.0",
		"@embedpdf/plugin-viewport": "^1.5.0",
		"@embedpdf/plugin-zoom": "^1.5.0",
		"@lucide/svelte": "^0.556.0",
		"@skeletonlabs/skeleton": "^4.7.4",
		"@skeletonlabs/skeleton-svelte": "^4.7.4",
		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.86.2",
		"drizzle-orm": "^0.45.0",
		"postgres": "^3.4.7",
		"zod": "^4.1.13"
	}
}
